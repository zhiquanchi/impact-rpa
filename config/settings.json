{
    "max_proposals": 1,
    "scroll_delay": 1.0,
    "click_delay": 0.5,
    "modal_wait": 20.0,
    "dry_run": false,
    "template_term": "Public Terms",
    "input_partner_groups_tag": true,
    "screenshot_on_error": true,
    "screenshot_full_page": false,
    "partner_groups_debug_logging": false,
    "partner_groups": {
        "mode": "ui",
        "api": {
            "url": "https://app.impact.com/partner-ui/api/relationship/groups",
            "method": "PUT",
            "headers": {
                "Content-Type": "application/json",
                "Accept": "application/json, text/plain, */*"
            },
            "body": {
                "psi": "{{creator_psi}}",
                "groups": [
                    "{{selected_tab}}"
                ]
            },
            "csrf_meta_selector": "",
            "csrf_header_name": "X-CSRF-Token",
            "success_status_min": 200,
            "success_status_max": 299
        },
        "id_by_name": {}
    },
    "vision_rpa": {
        "enabled": false,
        "api_key": "",
        "base_url": "",
        "model": "gpt-4o",
        "max_tokens": 1024,
        "temperature": 0.1,
        "timeout": 30,
        "browser_ui_offset_x": 0,
        "browser_ui_offset_y": 0
    }
}
